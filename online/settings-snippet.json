{
  "_comment": "Diesen Block in ~/.claude/settings.json unter 'hooks' einfuegen",
  "Notification": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "notify-send -u normal -t 5000 'Claude Code' 'Claude Code wartet auf deine Eingabe'"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/schutz.sh",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "~/.claude/hooks/pre-commit-check.sh",
          "timeout": 10
        },
        {
          "type": "agent",
          "prompt": "Siehe shared/hooks/pre-commit-kritiker-prompt.md fuer den vollstaendigen Prompt",
          "timeout": 120
        }
      ]
    }
  ]
}
